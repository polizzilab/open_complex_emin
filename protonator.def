Bootstrap: docker
From: ubuntu:22.04

%labels
    Maintainer polizzilab
    Description open_complex_emin — protein-ligand protonation and energy minimisation
    Source https://github.com/polizzilab/open_complex_emin

%environment
    # ambertools conda env  → antechamber, parmchk2
    # project .venv         → protonator and all Python deps
    export PATH="/opt/miniforge3/envs/ambertools/bin:/opt/open_complex_emin/.venv/bin:/opt/miniforge3/bin:$PATH"
    export CONDA_DEFAULT_ENV=base

%post
    export DEBIAN_FRONTEND=noninteractive

    # -----------------------------------------------------------------------
    # System packages
    # -----------------------------------------------------------------------
    apt-get update -qq && apt-get install -y -q --no-install-recommends \
        wget git build-essential ca-certificates libssl-dev \
        && rm -rf /var/lib/apt/lists/*

    # -----------------------------------------------------------------------
    # Fresh miniforge3 in /opt (not the host ~/miniforge3)
    # -----------------------------------------------------------------------
    wget -q \
        "https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh" \
        -O /tmp/miniforge.sh
    bash /tmp/miniforge.sh -b -p /opt/miniforge3
    rm /tmp/miniforge.sh
    export PATH="/opt/miniforge3/bin:$PATH"

    # -----------------------------------------------------------------------
    # uv via conda (base env) — used to manage Python 3.12 + .venv
    # AmberTools in a dedicated conda env so it can use whatever Python it
    # needs without conflicting with the project's Python 3.12 requirement.
    # -----------------------------------------------------------------------
    conda install -y -n base -c conda-forge uv
    conda create  -y -n ambertools -c conda-forge ambertools
    conda clean   -y --all

    # -----------------------------------------------------------------------
    # Clone protonator repo and install with uv — mirrors the normal workflow:
    #   1.  uv python install 3.12  → uv fetches its own CPython 3.12 build
    #   2.  uv sync                 → creates .venv, installs all PyPI deps
    #   3.  install_openff          → openff stack from GitHub into .venv
    # -----------------------------------------------------------------------
    git clone --depth 1 \
        https://github.com/polizzilab/open_complex_emin.git \
        /opt/open_complex_emin

    cd /opt/open_complex_emin
    uv python install 3.12
    uv sync
    uv pip install pip setuptools   # install_openff.sh calls python -m pip
    bash scripts/install_openff.sh

    # Tidy up pip/uv caches
    /opt/open_complex_emin/.venv/bin/pip cache purge 2>/dev/null || true

%runscript
    exec protonator "$@"

%help
    Protein-ligand protonation and energy minimisation pipeline.

    Build:
        singularity build protonator.sif protonator.def

    Usage:
        # Holo (protein + ligand):
        singularity run protonator.sif input.pdb --ligand-file ligand.sdf --output-dir out/
        singularity run protonator.sif input.pdb --smiles "CC(=O)O" --output-dir out/

        # Apo (protein only):
        singularity run protonator.sif input.pdb --apo --output-dir out/

        # Python API / arbitrary commands:
        singularity exec protonator.sif python -c "from protonator.ligand import prepare_ligand"

    Source: https://github.com/polizzilab/open_complex_emin

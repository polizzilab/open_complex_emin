Bootstrap: docker
From: ubuntu:22.04

%labels
    Maintainer polizzilab
    Description open_complex_emin — protein-ligand protonation and energy minimisation
    Source https://github.com/polizzilab/open_complex_emin

%environment
    # The protonator conda env contains everything: antechamber/parmchk2
    # (ambertools), the openff stack, openmm, rdkit, and protonator itself.
    export PATH="/opt/miniforge3/envs/protonator/bin:/opt/miniforge3/bin:$PATH"
    export CONDA_DEFAULT_ENV=protonator

%post
    export DEBIAN_FRONTEND=noninteractive

    # -----------------------------------------------------------------------
    # System packages
    # -----------------------------------------------------------------------
    apt-get update -qq && apt-get install -y -q --no-install-recommends \
        wget git ca-certificates \
        && rm -rf /var/lib/apt/lists/*

    # -----------------------------------------------------------------------
    # Fresh miniforge3 in /opt (not the host ~/miniforge3)
    # -----------------------------------------------------------------------
    wget -q \
        "https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh" \
        -O /tmp/miniforge.sh
    bash /tmp/miniforge.sh -b -p /opt/miniforge3
    rm /tmp/miniforge.sh
    export PATH="/opt/miniforge3/bin:$PATH"

    # -----------------------------------------------------------------------
    # Clone repo and create the conda environment from environment.yml.
    # conda-forge provides ambertools, the openff stack, openmm, rdkit, and
    # tblite — no GitHub-source builds or PyPI workarounds needed.
    # -----------------------------------------------------------------------
    GIT_TERMINAL_PROMPT=0 git clone --depth 1 \
        https://github.com/polizzilab/open_complex_emin.git \
        /opt/open_complex_emin

    conda env create -f /opt/open_complex_emin/environment.yml -n protonator

    # openmmforcefields is pure-Python; --no-deps prevents pip from pulling the
    # yanked PyPI openff-toolkit (its runtime deps are already in the conda env)
    /opt/miniforge3/envs/protonator/bin/pip install --no-deps openmmforcefields

    # Install the protonator package itself into the env (deps already present)
    /opt/miniforge3/envs/protonator/bin/pip install --no-deps \
        /opt/open_complex_emin

    conda clean -y --all

%runscript
    exec protonator "$@"

%test
    protonator --help > /dev/null && echo "protonator OK"

%help
    Protein-ligand protonation and energy minimisation pipeline.

    Build:
        singularity build protonator.sif protonator.def

    Usage:
        # Holo (protein + ligand):
        singularity run protonator.sif input.pdb --ligand-file ligand.sdf --output-dir out/
        singularity run protonator.sif input.pdb --smiles "CC(=O)O" --output-dir out/

        # Apo (protein only):
        singularity run protonator.sif input.pdb --apo --output-dir out/

        # Python API / arbitrary commands:
        singularity exec protonator.sif python -c "from protonator.ligand import prepare_ligand"

    Source: https://github.com/polizzilab/open_complex_emin
